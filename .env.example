# ==================== MySQL ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ai_customer_service

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT ====================
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
JWT_REMEMBER_HOURS=168

# ==================== DashScope (通义千问) ====================
DASHSCOPE_API_KEY=
LLM_MODEL=qwen-turbo
EMBEDDING_MODEL=text-embedding-v3

# ==================== ChromaDB ====================
CHROMA_PERSIST_PATH=./chroma_data

# ==================== 文件上传 ====================
UPLOAD_DIR=./uploads

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== AI 参数 ====================
AI_TIMEOUT=30
RATE_LIMIT_PER_MIN=10
TOP_K=5
SIMILARITY_THRESHOLD=0.5

# ==================== 文档切块 ====================
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# ==================== 服务地址 ====================
USER_SERVICE_URL=http://localhost:8001
CHAT_SERVICE_URL=http://localhost:8002
KNOWLEDGE_SERVICE_URL=http://localhost:8003
AI_SERVICE_URL=http://localhost:8004
